{
  "name": "churchdisplay-pro",
  "version": "0.3.1",
  "description": "教会敬拜投屏软件 - 多屏幕投影控制系统",
  "main": "electron/main.js",
  "build": {
    "appId": "com.aiden.churchdisplaypro",
    "productName": "churchdisplay-pro",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "data/**/*",
      "package.json",
      "LICENSE",
      "EULA.md"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5199 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:unsigned": "vite build && electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false",
    "license:generate": "node scripts/generate-license.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "pdfjs-dist": "^5.6.205",
    "pinyin-pro": "^3.28.0",
    "play-dl": "^1.9.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
