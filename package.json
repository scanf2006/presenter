{
  "name": "churchdisplay-pro",
  "version": "0.3.191",
  "description": "ChurchDisplay Pro - Worship projection system",
  "main": "electron/main.js",
  "build": {
    "appId": "com.aiden.churchdisplaypro",
    "productName": "churchdisplay-pro",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "LICENSE",
      "EULA.md"
    ],
    "asarUnpack": [
      "electron/ppt-convert.ps1"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "bible_*.db"
        ]
      },
      {
        "from": "data/seed",
        "to": "data-seed",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/**/*.test.js\"",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"electron/**/*.js\"",
    "format": "prettier --write .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5199 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:unsigned": "vite build && electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false",
    "electron:build:lite:unsigned": "vite build && electron-builder --win nsis --x64 --config electron-builder.lite.json --config.win.signAndEditExecutable=false",
    "license:generate": "node scripts/generate-license.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@fontsource/long-cang": "^5.2.8",
    "@fontsource/lxgw-wenkai-mono-tc": "^5.2.9",
    "@fontsource/lxgw-wenkai-tc": "^5.2.9",
    "@fontsource/ma-shan-zheng": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@fontsource/zcool-kuaile": "^5.2.8",
    "@fontsource/zcool-qingke-huangyou": "^5.2.8",
    "@fontsource/zcool-xiaowei": "^5.2.8",
    "@fontsource/zhi-mang-xing": "^5.2.8",
    "play-dl": "^1.9.7",
    "sql.js": "^1.14.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "pdfjs-dist": "^5.6.205",
    "prettier": "^3.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
