{
  "appId": "com.aiden.churchdisplaypro",
  "productName": "churchdisplay-pro",
  "files": [
    "electron/**/*",
    "dist/**/*",
    "!dist/win-unpacked{,/**}",
    "!dist/*.exe",
    "!dist/*.blockmap",
    "!dist/*.zip",
    "!dist/__*",
    "package.json",
    "LICENSE",
    "EULA.md"
  ],
  "asarUnpack": [
    "electron/ppt-convert.ps1",
    "node_modules/@stagetimerio/grandiose/dist/**"
  ],
  "extraResources": [
    {
      "from": "data",
      "to": "data",
      "filter": [
        "bible_*.db"
      ]
    }
  ],
  "win": {
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
